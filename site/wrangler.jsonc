{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stefanprodan-com",
  "compatibility_date": "2026-06-30",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  // workers.dev stays on until the custom-domain cutover is verified
  "workers_dev": true,
  "preview_urls": true
  // "routes" is added at cutover: [{ "pattern": "stefanprodan.com", "custom_domain": true }]
}
