---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import stefan from '../assets/stefan.jpeg';

const description =
  "Stefan Prodan's open source portfolio and tech blog. " +
  'Principal Consultant at ControlPlane, core maintainer of the CNCF projects Flux and Flagger.';
---

<BaseLayout title="Stefan Prodan" description={description}>
  <section class="hero">
    <Image class="avatar" src={stefan} alt="Stefan Prodan" width={240} height={240} densities={[1, 2]} loading="eager" />
    <div>
      <p class="meta">Principal Consultant at ControlPlane</p>
      <p class="prompt">$ whoami</p>
      <h1>Stefan Prodan</h1>
      <p>
        Passionate about OSS, Cloud Native and Kubernetes. Core maintainer of CNCF projects:
        Flux, Flagger and the GitOps Toolkit.
      </p>
      <div class="actions">
        <a class="button button-primary" href="/blog/">Blog</a>
        <a class="button" href="/portfolio/open-source/">Portfolio</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Center the hero in the space between header and footer */
  :global(main:has(.hero)) {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 3.5rem 0;
  }

  .avatar {
    border-radius: 10px;
    border: 1px solid var(--accent);
    flex-shrink: 0;
  }

  .prompt {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent);
    margin: 1rem 0 0;
  }

  h1 {
    margin: 0.25rem 0 1rem;
    font-size: 2.5rem;
  }

  .hero > div > p:not(.meta) {
    color: var(--muted);
    max-width: 34rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
      padding: 2rem 0;
    }

    .actions {
      justify-content: center;
    }

    .avatar {
      width: 180px;
      height: 180px;
    }
  }
</style>
