---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import stefan from '../assets/stefan.jpeg';

const description =
  "Stefan Prodan's open source portfolio and tech blog. " +
  'Head of development at ControlPlane, core maintainer of the CNCF projects Flux and Flagger.';
---

<BaseLayout title="Stefan Prodan" description={description}>
  <section class="hero">
    <div class="side">
      <Image class="avatar" src={stefan} alt="Stefan Prodan" width={240} height={240} densities={[1, 2]} loading="eager" />
      <div class="term" aria-hidden="true">
        <div class="term-bar">
          <span class="dot close"></span>
          <span class="dot min"></span>
          <span class="dot max"></span>
          <span class="term-title">zsh</span>
        </div>
        <p class="term-body">
          <span class="prompt">$&nbsp;</span><span id="typer"></span><span class="cursor"></span>
        </p>
      </div>
    </div>
    <div>
      <p class="meta">Head of development at ControlPlane</p>
      <h1>Stefan Prodan</h1>
      <p>
        Passionate about OSS, Cloud Native and Kubernetes. Core maintainer of the CNCF Flux CD project.
      </p>
      <div class="actions">
        <a class="button button-primary" href="/blog/">Blog</a>
        <a class="button" href="/portfolio/open-source/">Portfolio</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Sit the hero in the upper third of the space between header and footer */
  :global(main:has(.hero)) {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .hero {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
    padding: 4.5vh 0 3rem;
  }

  .side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    flex-shrink: 0;
    width: 240px;
  }

  .avatar {
    border-radius: 10px;
    border: 1px solid var(--accent);
  }

  .term {
    font-family: var(--font-mono);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.25);
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.close {
    background: #ff5f57;
  }

  .dot.min {
    background: #febc2e;
  }

  .dot.max {
    background: #28c840;
  }

  .term-title {
    flex: 1;
    text-align: center;
    font-size: 0.7rem;
    color: var(--muted);
    /* Visually center between the dots and the right edge */
    margin-left: -42px;
  }

  .term-body {
    margin: 0;
    font-size: 0.8rem;
    color: var(--muted);
    padding: 0.6rem 0.7rem 0.9rem;
    white-space: nowrap;
    overflow: hidden;
  }

  .term .prompt {
    color: var(--accent);
  }

  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    margin-left: 2px;
    vertical-align: -0.15em;
    background: var(--accent);
    animation: blink 1s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  h1 {
    margin: 0.25rem 0 1rem;
    font-size: 2.5rem;
  }

  .hero > div > p:not(.meta) {
    color: var(--muted);
    max-width: 34rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  /* Compact buttons so the text column stays within the avatar height */
  .actions .button {
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
      padding: 2rem 0;
    }

    .actions {
      justify-content: center;
    }

    .side {
      width: 180px;
      margin: 0 auto;
    }

    .avatar {
      width: 180px;
      height: 180px;
    }

    .term {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  const typer = document.getElementById('typer');
  if (typer) {
    const phrases = ['hacking on flux operator', 'hacking on timoni', 'hacking on flagger'];
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      typer.textContent = phrases[0];
    } else {
      const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
      (async () => {
        for (let i = 0; ; i++) {
          const phrase = phrases[i % phrases.length];
          for (let c = 1; c <= phrase.length; c++) {
            typer.textContent = phrase.slice(0, c);
            await sleep(80);
          }
          await sleep(2200);
          for (let c = phrase.length - 1; c >= 0; c--) {
            typer.textContent = phrase.slice(0, c);
            await sleep(35);
          }
          await sleep(500);
        }
      })();
    }
  }
</script>
