  },
  {
    img: 'fluxcon-na-2025-speaker',
    name: 'FluxCon NA 2025 Speaker',
    href: 'https://www.credly.com/badges/4c3f0207-5387-4eec-8843-274e3fb8938a',
  },
  {
    img: 'kubecon-na-2025-speaker',
    name: 'Speaker: KubeCon + CloudNativeCon North America 2025',
    href: 'https://www.credly.com/badges/9792884b-a3ed-4fbc-8a67-f1f8821d1254',
  },
  {
    img: 'osff-london-2025-speaker',
    name: 'Speaker: Open Source in Finance Forum London 2025',
    href: 'https://www.credly.com/badges/77b4f79f-e377-4e3e-9bd8-ab5ce0a46ec8',
  },
  {
    img: 'kubecon-eu-2025-speaker',
    name: 'Speaker: KubeCon + CloudNativeCon Europe 2025',
    href: 'https://www.credly.com/badges/4e91e1c7-fc85-4bc8-affe-dabd3ca10210',
  },
  {
    img: 'kubecon-eu-2024-speaker',
    name: 'Speaker: KubeCon + CloudNativeCon Europe 2024',
    href: 'https://www.credly.com/badges/3dc8d1fd-be46-4542-ae8c-d6dc96c2a7f4',
  },
  {
    img: 'gitopscon-eu-2023-speaker',
    name: 'Speaker: GitOpsCon Europe 2023',
    href: 'https://www.credly.com/badges/b38c49ba-745d-4a3e-b0df-602d13981ace',
  },
  {
