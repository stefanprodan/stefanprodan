---
import { Image } from 'astro:assets';
import ProseLayout from '../../layouts/ProseLayout.astro';
import stefanprodan from '../../assets/stefanprodan.jpeg';
import type { ImageMetadata } from 'astro';

const badgeImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/badges/*.png', { eager: true });
const badgeImage = (file: string) => badgeImages[`../../assets/badges/${file}.png`].default;

const frontmatter = {
  title: 'Biography',
  description: 'Biography of Stefan Prodan, Software Engineer and open source contributor.',
};

const career = [
  {
    period: '2024-present',
    org: 'ControlPlane',
    role: 'Head of Development',
    text: 'Leading the Flux CD Enterprise product at <a href="https://control-plane.io/enterprise-for-flux-cd/" target="_blank" rel="noopener">ControlPlane</a>.',
  },
  {
    period: '2017-2023',
    org: 'Weaveworks',
    role: 'Principal Engineer',
    text: 'Architecting and maintaining Flux, Flagger and the GitOps Toolkit.',
  },
  {
    period: 'before 2017',
    org: 'Consulting',
    role: 'Software Architect, DevOps Consultant',
    text: 'Helping companies embrace DevOps and the SRE movement.',
  },
];

/* All badges from credly.com/users/stefanprodan, newest first */
const badges = [
  {
