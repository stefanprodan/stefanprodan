---
import { Image } from 'astro:assets';
import ProseLayout from '../../layouts/ProseLayout.astro';
import stefanprodan from '../../assets/stefanprodan.jpeg';

const frontmatter = {
  title: 'Biography',
  description: 'Biography of Stefan Prodan, Software Engineer and open source contributor.',
};

const career = [
  {
    period: '2024-present',
    org: 'ControlPlane',
    role: 'Head of Development',
    text: 'Leading the Flux CD Enterprise product at <a href="https://control-plane.io/enterprise-for-flux-cd/">control-plane.io</a>.',
  },
  {
    period: '2017-2023',
    org: 'Weaveworks',
    role: 'Principal Engineer',
    text: 'Architecting and maintaining Flux, Flagger and the GitOps Toolkit.',
  },
  {
    period: 'before 2017',
    org: 'Consulting',
    role: 'Software Architect, DevOps Consultant',
    text: 'Helping companies embrace DevOps and the SRE movement.',
  },
];

const contact = [
  { label: 'Slack', text: '@stefanprodan on cloud-native.slack.com', href: 'https://cloud-native.slack.com/team/ULPRMFH38' },
  { label: 'GitHub', text: '@stefanprodan', href: 'https://github.com/stefanprodan' },
  { label: 'LinkedIn', text: '@stefanprodan', href: 'https://linkedin.com/in/stefanprodan' },
  { label: 'X', text: '@stefanprodan', href: 'https://x.com/stefanprodan' },
  { label: 'Substack', text: 'stefanprodan.substack.com', href: 'https://stefanprodan.substack.com/' },
];
---

<ProseLayout frontmatter={frontmatter}>
  <div class="bio">
    <Image class="portrait" src={stefanprodan} alt="Stefan Prodan" width={220} height={293} densities={[1, 2]} />
    <div>
      <p class="meta">Software Engineer &middot; Open Source Contributor</p>
      <p class="lede">
        Stefan is the creator of Flagger, the progressive delivery operator for Kubernetes, and a core maintainer of
        Flux CD, a <a href="https://cncf.io">CNCF</a> graduated project.
      </p>
      <p class="lede">
        He has over 15 years of experience with software development, enjoys programming in Go, and gives talks about
        distributed systems.
      </p>
    </div>
  </div>

  <h2>Career</h2>

  <ol class="career">
    {
      career.map(({ period, org, role, text }) => (
        <li>
          <span class="meta period">{period}</span>
          <div>
            <p class="org">
              {org} <span class="meta">{role}</span>
            </p>
            <p class="what" set:html={text} />
          </div>
        </li>
      ))
    }
  </ol>

  <h2>Contact</h2>

  <ul class="contact">
    {
      contact.map(({ label, text, href }) => (
        <li>
          <span class="meta label">{label}</span>
          <a href={href}>{text}</a>
        </li>
      ))
    }
  </ul>
</ProseLayout>

<style>
  .bio {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin: 1.5rem 0 1rem;
  }

  .portrait {
    border-radius: 10px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .lede {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .career {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .career li {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
  }

  .career li:last-child {
    border-bottom: 1px solid var(--border);
  }

  .period {
    color: var(--accent-2);
    padding-top: 0.15rem;
  }

  .career p {
    margin: 0;
  }

  .org {
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .org .meta {
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .what {
    color: var(--muted);
    margin-top: 0.25rem !important;
  }

  /* set:html content skips scoped styles; in-text links must be underlined */
  .what :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .contact li {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1.5rem;
    padding: 0.4rem 0;
  }

  @media (max-width: 640px) {
    .bio {
      flex-direction: column;
      gap: 1.5rem;
    }

    .career li,
    .contact li {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
