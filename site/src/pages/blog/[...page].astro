---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getSortedPosts, paginatePosts, type Post } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return paginatePosts(posts).map(({ page, total, posts }) => ({
    params: { page: page === 1 ? undefined : `page/${page}` },
    props: { posts, page, total },
  }));
}

interface Props {
  posts: Post[];
  page: number;
  total: number;
}

const { posts, page, total } = Astro.props;
const title = page === 1 ? 'Blog' : `Blog - page ${page}`;
---

<BaseLayout title={`${title} | Stefan Prodan`} description="Stefan Prodan's tech blog: GitOps, Flux, Kubernetes and Cloud Native.">
  <h1>Blog</h1>
  {posts.map((post) => <PostCard post={post} />)}
  <Pagination base="/blog" page={page} total={total} />
</BaseLayout>
