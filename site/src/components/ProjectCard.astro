---
interface Props {
  id: string;
  name: string;
  role: string;
  period: string;
  repos: string[];
  stack: string[];
  logo?: string;
  icon?: 'github' | 'git';
}

const { id, name, role, period, repos, stack, logo, icon = 'github' } = Astro.props;
const repoLabel = (url: string) => url.replace('https://github.com/', '');
---

<section class="project" id={id}>
  <header>
    <div class="ident">
      {
        logo ? (
          <img src={logo} alt="" width="40" height="40" />
        ) : (
          <span class="tile" aria-hidden="true">
            {
              icon === 'git' ? (
                <svg width="26" height="26" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
                </svg>
              ) : (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                </svg>
              )
            }
          </span>
        )
      }
      <h2>{name}</h2>
    </div>
    <p class="meta">{role} &middot; {period}</p>
  </header>
  <div class="desc">
    <slot />
  </div>
  <footer>
    <ul class:list={['repos', { multi: repos.length > 1 }]}>
      {
        repos.map((repo) => (
          <li class="meta">
            <svg class="repo-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
            <a href={repo}>{repoLabel(repo)}</a>
          </li>
        ))
      }
    </ul>
    <p class="stack">
      {stack.map((s) => <code>{s}</code>)}
    </p>
  </footer>
</section>

<style>
  .project {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem 1.75rem;
    margin: 1.5rem 0;
  }

  header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.25rem 1rem;
  }

  .ident {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ident img {
    border-radius: 4px;
    flex-shrink: 0;
  }

  .tile {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    opacity: 0.5;
  }

  h2 {
    font-size: 1.15rem;
    margin: 0;
    scroll-margin-top: 1rem;
  }

  header .meta {
    margin: 0;
  }

  .desc {
    color: var(--muted);
  }

  .desc :global(p) {
    margin: 0.75rem 0;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-top: 1rem;
  }

  .repos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem 1.5rem;
  }

  .repos.multi {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .repos li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .repo-icon {
    color: var(--muted);
    opacity: 0.5;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .repos.multi {
      grid-template-columns: 1fr;
    }
  }

  .stack {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack code {
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
