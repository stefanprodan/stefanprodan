---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  wide?: boolean;
}

const { wide = false } = Astro.props;
---

<header>
  <div class:list={['inner', { wide }]}>
    <a class="wordmark" href="/"><span class="tilde">~</span>/stefanprodan</a>
    <nav id="site-nav" aria-label="Main">
      <a href="/blog/">Blog</a>
      <a href="/portfolio/open-source/">Portfolio</a>
      <a href="/portfolio/biography/">Bio</a>
    </nav>
    <div class="controls">
      <ThemeToggle />
      <button class="menu-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
        <svg
          class="icon-burger"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
        <svg
          class="icon-close"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="5" y1="5" x2="19" y2="19"></line>
          <line x1="19" y1="5" x2="5" y2="19"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }

  .inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0.85rem var(--space);
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  /* Match the page container so the menu aligns with rail layouts */
  .inner.wide {
    max-width: var(--measure-wide);
  }

  .wordmark {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1rem;
    color: var(--fg);
    margin-right: auto;
  }

  .wordmark:hover {
    text-decoration: none;
  }

  .tilde {
    color: var(--accent);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  nav a {
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: lowercase;
  }

  nav a::before {
    content: './';
    color: var(--muted);
  }

  nav a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  nav a:hover::before {
    color: var(--accent);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .menu-toggle {
    display: none;
    align-items: center;
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--muted);
    padding: 0.35rem 0.5rem;
    cursor: pointer;
  }

  .menu-toggle:hover {
    color: var(--fg);
    border-color: var(--muted);
  }

  .menu-toggle .icon-close {
    display: none;
  }

  .menu-toggle[aria-expanded='true'] .icon-burger {
    display: none;
  }

  .menu-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  /* The mono nav is wider than a phone; collapse it behind a hamburger */
  @media (max-width: 560px) {
    .inner {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .menu-toggle {
      display: inline-flex;
    }

    nav {
      display: none;
    }

    nav.open {
      display: flex;
      order: 4;
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
      padding: 0.75rem 0 0.35rem;
      border-top: 1px solid var(--border);
    }
  }
</style>

<script>
  const button = document.querySelector('.menu-toggle');
  const nav = document.getElementById('site-nav');
  if (button && nav) {
    button.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      button.setAttribute('aria-expanded', String(open));
    });
  }
</script>
