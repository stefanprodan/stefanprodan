---
interface Props {
  wide?: boolean;
}

const { wide = false } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <div class:list={['inner', { wide }]}>
    <nav class="meta" aria-label="Social links">
      <a href="https://github.com/stefanprodan" rel="me">GitHub</a>
      <a href="https://linkedin.com/in/stefanprodan" rel="me">LinkedIn</a>
      <a href="https://x.com/stefanprodan" rel="me">X</a>
      <a href="https://cloud-native.slack.com/team/ULPRMFH38">Slack</a>
      <a href="/rss.xml">RSS</a>
    </nav>
    <p class="meta">Copyright &copy; {year} Stefan Prodan</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
  }

  .inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1.5rem var(--space);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  /* Match the page container so the footer aligns with rail layouts */
  .inner.wide {
    max-width: var(--measure-wide);
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    color: var(--muted);
  }

  nav a:hover {
    color: var(--accent);
  }

  p {
    margin: 0;
  }
</style>
