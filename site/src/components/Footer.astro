<style>
  footer {
    border-top: 1px solid var(--border);
  }

  .inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1.5rem var(--space);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  /* Match the page container so the footer aligns with rail layouts */
  .inner.wide {
    max-width: var(--measure-wide);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  nav a {
    display: flex;
    color: var(--muted);
  }

  nav a:hover {
    color: var(--accent);
  }

  p {
    margin: 0;
  }
</style>
